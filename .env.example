# ═══════════════════════════════════════════════════════════════
# SHARED PIPELINE CONFIG — defaults from config/defaults.yml
# Override here only if you need a local-specific value.
# These values must match across local Docker and AWS deployments.
# ═══════════════════════════════════════════════════════════════
LLM_TEMPERATURE=0.7              # Default from config/defaults.yml
LLM_MAX_TOKENS=64768             # Default from config/defaults.yml
LLM_TIMEOUT=30                   # Default from config/defaults.yml
LLM_RETRIES=3                    # Default from config/defaults.yml
VALIDATOR_ENABLED=true           # Default from config/defaults.yml
VALIDATION_REJECTION_THRESHOLD=10  # Default from config/defaults.yml
VALIDATOR_ENRICHMENT_ENABLED=true  # Default from config/defaults.yml
ENRICHMENT_CACHE_TTL=86400       # Default from config/defaults.yml (24 hours)
ENRICHMENT_TIMEOUT=30            # Default from config/defaults.yml
ENRICHMENT_GEOCODING_PROVIDERS=["arcgis", "nominatim", "census"]  # Default from config/defaults.yml
GEOCODING_PROVIDER=arcgis        # Default from config/defaults.yml
GEOCODING_ENABLE_FALLBACK=true   # Default from config/defaults.yml
GEOCODING_MAX_RETRIES=3          # Default from config/defaults.yml
GEOCODING_TIMEOUT=10             # Default from config/defaults.yml
CONTENT_STORE_ENABLED=true       # Default from config/defaults.yml
RECONCILER_LOCATION_TOLERANCE=0.0001  # Default from config/defaults.yml

# ═══════════════════════════════════════════════════════════════
# ENVIRONMENT-SPECIFIC — different values on AWS vs local
# ═══════════════════════════════════════════════════════════════

# Python Environment
PYTHONPATH=/app
DEBUG=1

# CORS Configuration
cors_origins=["*"]

# Database Configuration
DATABASE_URL=postgresql+psycopg2://postgres:your_secure_password@db:5432/pantry_pirate_radio
MAX_CONNECTIONS=10

# PostgreSQL Initialization
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=pantry_pirate_radio

# Redis Configuration
REDIS_URL=redis://cache:6379/0
REDIS_POOL_SIZE=10
REDIS_TTL_SECONDS=2592000

# Queue Backend: redis (local) or sqs (AWS)
QUEUE_BACKEND=redis

# LLM Provider: openai (local) or bedrock (AWS)
LLM_PROVIDER=openai
LLM_MODEL_NAME=google/gemini-2.0-flash-001
LLM_RESPONSE_FORMAT=json_object

# Content Store Backend: file (local) or s3 (AWS)
CONTENT_STORE_BACKEND=file
CONTENT_STORE_PATH=/data-repo

# Logging Settings
LOG_LEVEL=INFO
JSON_LOGS=true

# Test Environment
TEST_DATABASE_URL=postgresql+psycopg2://postgres:your_secure_password@db:5432/test_pantry_pirate_radio
TEST_REDIS_URL=redis://cache:6379/1
POSTGRES_TEST_PASSWORD=test
POSTGRES_TEST_DB=test_pantry_pirate_radio

# HSDS Validation Settings
HSDS_MIN_CONFIDENCE=0.82
HSDS_RETRY_THRESHOLD=0.65
HSDS_MAX_RETRIES=5

# ═══════════════════════════════════════════════════════════════
# SECRETS — API keys, passwords (never commit real values)
# On AWS: CDK reads these from .env at deploy time → Secrets Manager
# ═══════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=your_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ARCGIS_API_KEY=
DATA_REPO_TOKEN=your_github_personal_access_token_here

# ═══════════════════════════════════════════════════════════════
# LOCAL-ONLY — not used on AWS
# ═══════════════════════════════════════════════════════════════

# OpenAI-compatible API Configuration
API_BASE_URL=https://openrouter.ai/api/v1
API_VERSION=2024-02-01
HTTP_REFERER=https://github.com/openrouter-ai/openrouter-python
APP_TITLE=Pantry Pirate Radio

# Claude Quota Management
CLAUDE_QUOTA_RETRY_DELAY=3600
CLAUDE_QUOTA_MAX_DELAY=14400
CLAUDE_QUOTA_BACKOFF_MULTIPLIER=1.5

# AWS Bedrock Configuration (if using bedrock provider locally)
# LLM_PROVIDER=bedrock
# LLM_MODEL_NAME=anthropic.claude-sonnet-4-6
# AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=your_sso_profile

# LLM Queue Settings
WORKER_COUNT=1
LLM_QUEUE_KEY=llm:jobs
LLM_CONSUMER_GROUP=llm-workers

# Data Repository Configuration
DATA_REPO_URL=https://github.com/For-The-Greater-Good/HAARRRvest.git
DATA_REPO_PATH=/data-repo

# Publishing Configuration
DAYS_TO_SYNC=7
PUBLISHER_CHECK_INTERVAL=300
ERROR_RETRY_DELAY=60
PUBLISHER_PUSH_ENABLED=false

# Cloudflare Tunnel (Production Only)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Git Configuration for HAARRRvest Publisher
GIT_USER_EMAIL=pantry-pirate-radio@example.com
GIT_USER_NAME=Pantry Pirate Radio Publisher

# SQL Dump Safety Settings
SQL_DUMP_MIN_RECORDS=100
SQL_DUMP_RATCHET_PERCENTAGE=0.9
ALLOW_EMPTY_SQL_DUMP=false

# Geocoding (local-only settings, not shared)
GEOCODING_CACHE_TTL=2592000
GEOCODING_RATE_LIMIT=0.5
NOMINATIM_USER_AGENT=pantry-pirate-radio
NOMINATIM_RATE_LIMIT=1.1

# Enrichment (local-only provider settings)
ENRICHMENT_MAX_RETRIES=3
ENRICHMENT_CIRCUIT_BREAKER_THRESHOLD=5
ENRICHMENT_CIRCUIT_BREAKER_COOLDOWN=300

# Output Configuration
OUTPUT_DIR=/app/outputs

# Map Data Export Configuration
MAP_GROUPING_RADIUS_METERS=150

# Validation Rules Configuration
VALIDATION_ENABLE_US_BOUNDS_CHECK=true
VALIDATION_ENABLE_TEST_DATA_DETECTION=true
VALIDATION_ENABLE_STATE_VERIFICATION=true
VALIDATION_ENABLE_PLACEHOLDER_DETECTION=true

# Tightbeam API Configuration
TIGHTBEAM_ENABLED=true
TIGHTBEAM_API_KEYS=  # Comma-separated API keys for tightbeam endpoints

# SQS Backend Configuration (AWS only, uncomment if needed locally)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pantry-pirate-radio-llm
# SQS_JOBS_TABLE=pantry-pirate-radio-jobs
# SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789/pantry-pirate-radio-llm-dlq

# S3 Backend Configuration (AWS only, uncomment if needed locally)
# CONTENT_STORE_S3_BUCKET=pantry-pirate-radio-content
# CONTENT_STORE_DYNAMODB_TABLE=pantry-pirate-radio-content-index
# CONTENT_STORE_S3_PREFIX=content-store/
